# Sao chep file nay thanh .env va dien thong tin thuc te

# Supabase PostgreSQL URL
# Luu y: neu password co ky tu @ thi encode thanh %40
# Vi du: password "abc@123" -> "abc%40123"
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# LinkedIn (tuy chon - de trong neu khong can crawl LinkedIn)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
