# Sao chep file nay thanh .env va dien thong tin thuc te

# ─────────────────────────────────────────────────────────
# Database — chi can 1 trong 2 cach duoi day
# ─────────────────────────────────────────────────────────

# Cach 1: Ket noi Postgres truc tiep (dung khi chay local / lan dau tao bang)
# Luu y: neu password co ky tu dac biet (@, #, ...) thi phai URL-encode
# Vi du: password "abc@123" -> "abc%40123"
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# Cach 2: Supabase REST API (dung tren GitHub Actions / Streamlit Cloud)
# Lay o Supabase Dashboard > Project Settings > API
SUPABASE_URL=
SUPABASE_KEY=

# ─────────────────────────────────────────────────────────
# Tuy chon crawler
# ─────────────────────────────────────────────────────────
CRAWL_DELAY_SECONDS=2
MAX_PAGES_PER_SOURCE=5

# ─────────────────────────────────────────────────────────
# Thong bao hang ngay (notify.py) — de trong neu khong dung kenh do
# ─────────────────────────────────────────────────────────

# Telegram: tao bot qua @BotFather de lay token, lay chat_id bang cach
# nhan tin cho bot roi mo https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email: neu dung Gmail va co bat 2FA, phai tao "App Password" rieng
# (khong dung mat khau Gmail thuong)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
